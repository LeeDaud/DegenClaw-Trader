# DegenClaw Alpha Engine - 环境配置

# 数据库
DC_DB_PATH=data/degenclaw.db

# FastAPI
DC_HOST=0.0.0.0
DC_PORT=8000
DC_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 采集器模式 (mock / real)
COLLECTOR_SOURCE=mock

# DegenClaw API
DEGENCLAW_ENDPOINT=
DEGENCLAW_APP_BASE_URL=https://app.virtuals.io

# 市场数据 API
DEXSCREENER_ENDPOINT=https://api.dexscreener.com/latest/dex

# 采集间隔 (秒)
POLL_INTERVAL_SECONDS=300

# 请求超时 (秒)
REQUEST_TIMEOUT_SECONDS=15

# 日志级别
LOG_LEVEL=INFO

# 飞书机器人 webhook
FEISHU_WEBHOOK_URL=
FEISHU_ALERTS_ENABLED=false

# Pot PnL 监控 4 级阈值
# 触发值 = max(PnL 变化占 capital %, ROI 变化绝对值)
# 抑制门（低于此值不触发任何告警）
POT_PNL_CHANGE_THRESHOLD=10.0
POT_ROI_CHANGE_THRESHOLD=5.0
# 4 级 PnL 阈值 (% of capital)
DC_POT_PNL_TIER_INFO_PCT=3.0
DC_POT_PNL_TIER_WARNING_PCT=8.0
DC_POT_PNL_TIER_IMPORTANT_PCT=15.0
DC_POT_PNL_TIER_CRITICAL_PCT=25.0
# 4 级 ROI 阈值 (%)
DC_POT_ROI_TIER_INFO_PCT=2.0
DC_POT_ROI_TIER_WARNING_PCT=5.0
DC_POT_ROI_TIER_IMPORTANT_PCT=10.0
DC_POT_ROI_TIER_CRITICAL_PCT=20.0

# SignalHub 路径 (Python import 用)
SIGNALHUB_PATH=
